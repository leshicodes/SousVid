# ── OpenRouter (required) ────────────────────────────────────────────────────
# Get your API key at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-your-key-here

# Any multimodal model available on OpenRouter. Gemini Flash is the cheapest.
# See https://openrouter.ai/models for options.
OPENROUTER_MODEL=google/gemini-flash-1.5

# ── Mealie (optional) ────────────────────────────────────────────────────────
# Leave blank to skip Mealie integration. Recipes can still be downloaded as
# JSON or Markdown without a Mealie instance.
MEALIE_URL=http://your-mealie-host:9925
MEALIE_API_TOKEN=your-mealie-api-token-here

# ── Whisper ──────────────────────────────────────────────────────────────────
# Model size: tiny | base | small | medium | large-v3
# Larger models are more accurate but require more RAM and are slower.
# See the README's Whisper model guide for details.
WHISPER_MODEL=small

# Device: cpu | cuda
# Use cuda only if you have an Nvidia GPU and the CUDA Dockerfile variant.
WHISPER_DEVICE=cpu

# Compute type: int8 (for CPU) | float16 (for GPU)
WHISPER_COMPUTE_TYPE=int8

# ── Video processing ─────────────────────────────────────────────────────────
# Number of frames extracted from the video and sent to the LLM.
# More frames = better accuracy, slightly higher LLM cost. 6 is a good default.
MAX_FRAMES=6

# Path to cookies file inside the container. Change only if you have a custom
# Docker volume setup. The default matches the docker-compose.yml mount.
# COOKIES_FILE=/app/cookies/cookies.txt

# -- Redis / Celery -----------------------------------------------------------
# Default matches the docker-compose.yml service name.
# REDIS_URL=redis://redis:6379/0
